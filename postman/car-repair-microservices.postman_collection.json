{
  "info": {
    "name": "Car Repair Microservices",
    "_postman_id": "10b36b2a-498d-44e6-bf08-4a3b9837c61e",
    "description": "Smoke tests for Keycloak, Config Server and API Gateway.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "keycloakUrl", "value": "http://localhost:8180" },
    { "key": "configUrl", "value": "http://localhost:8888" },
    { "key": "realm", "value": "car-repair" },
    { "key": "clientId", "value": "car-repair-gateway" },
    { "key": "username", "value": "testuser" },
    { "key": "password", "value": "testpass" }
  ],
  "item": [
    {
      "name": "Keycloak Well-Known",
      "request": {
        "method": "GET",
        "url": "{{keycloakUrl}}/realms/{{realm}}/.well-known/openid-configuration"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Issuer contains realm', function () { pm.expect(body.issuer).to.include('/realms/{{realm}}'); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Config Server Default",
      "request": {
        "method": "GET",
        "url": "{{configUrl}}/config-server/default"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Config server name is returned', function () { pm.expect(body.name).to.eql('config-server'); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Gateway Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/actuator/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{username}}@example.com\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{baseUrl}}/users/register"
      }
    },
    {
      "name": "Login URL",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users/login"
      }
    }
  ]
}
